<?xml version="1.0"?>
<model>
  <name>x500_nectar</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    PX4 x500 quadrotor with the Nectar SDK sensor suite added: a forward RGBD
    camera (D435i analog, /front_camera), a downward RGB camera (/down_camera),
    and a downward single-beam lidar rangefinder (/lidar/range). Mirrors PX4's
    own x500_depth pattern (merge the x500 base, attach sensors to base_link via
    fixed joints) so the drone keeps standard PX4 dynamics while exposing the
    same sensor topics as the ArduPilot iris used in Nectar's worlds.
  </description>
</model>
