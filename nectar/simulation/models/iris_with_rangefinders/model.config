<?xml version="1.0"?>
<model>
  <name>Iris with Rangefinders</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <description>
    iris_with_standoffs plus ArduPilotPlugin and three single-ray gpu_lidar
    rangefinders (down, front, back) fed to ArduPilot as rng_1/rng_2/rng_3.
    Used to exercise multi-orientation DISTANCE_SENSOR telemetry in SITL.
  </description>

  <depend>
    <model>
      <uri>model://iris_with_standoffs</uri>
      <version>2.0</version>
    </model>
  </depend>
</model>
