<?xml version="1.0"?>
<model>
  <name>outdoor_field_scenery</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Nectar SDK shared outdoor mission scenery: gate (two posts + crossbar) and
    obstacle field (boxes + cylinders). Firmware-agnostic — included by both the
    ArduPilot (outdoor_field.sdf) and PX4 (outdoor_field_px4.sdf) worlds so both
    fly the identical environment. The drone and sensors are added per firmware.
  </description>
</model>
